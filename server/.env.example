# ╔════════════════════════════════════════════════════════════════════╗
# ║  Ada's Cafe' QR System — .env Setup                                ║
# ╚════════════════════════════════════════════════════════════════════╝
#
# วิธีเปิดใช้งาน (Run these commands to configure environment):
#   Windows: copy .env.example .env
#   Linux/macOS: cp .env.example .env
#
# วิธีหา IP ของแต่ละเครื่อง (How to find local network IPs):
# ──────────────────────────────────────────────────────────────────────
# BRIDGE_SERVER_IP (เครื่องคอมพิวเตอร์ที่ใช้รัน Node.js server ตัวนี้):
#   Windows: เปิด CMD / Terminal → พิมพ์ ipconfig
#            ดูบรรทัด "IPv4 Address" ของ network WiFi / LAN
#            ตัวอย่าง: 192.168.1.100
#
# KITCHEN_PRINTER_IP (เครื่องพิมพ์สลิปในห้องครัว):
#   ปิดสวิตช์เครื่องพิมพ์ → กดปุ่ม Feed ค้างไว้ → เปิดสวิตช์เครื่องพิมพ์ค้างไว้
#   เครื่องพิมพ์จะพิมพ์กระดาษ self-test slip ออกมา มีระบุบรรทัด IP address
#   ตัวอย่าง: 192.168.1.150
# ──────────────────────────────────────────────────────────────────────

# The local IP address of this Server PC
BRIDGE_SERVER_IP=YOUR_SERVER_IP_HERE

# Express server listening port
BRIDGE_PORT=3000

# The local IP address of the kitchen thermal printer (TCP Port 9100)
KITCHEN_PRINTER_IP=YOUR_PRINTER_IP_HERE
KITCHEN_PRINTER_PORT=9100

# Total tables in the cafe
TABLE_COUNT=32

# Tables 1 to 20 are Indoor (อินดอร์)
SECTION_INDOOR=20

# Tables 21 to 32 are Outdoor (เอาท์ดอร์)
SECTION_OUTDOOR=12

# Default estimated preparation time shown to customers
DEFAULT_WAIT_MINUTES=10
